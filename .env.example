# ── Database ──────────────────────────────────────────────────────────────────
TOKENLEAK_DB_TYPE=sqlite          # sqlite | postgres
TOKENLEAK_DB_PATH=tokenleak.db    # SQLite only
TOKENLEAK_DB_HOST=localhost       # PostgreSQL only
TOKENLEAK_DB_PORT=5432            # PostgreSQL only
TOKENLEAK_DB_NAME=tokenleak       # PostgreSQL only
TOKENLEAK_DB_USER=tokenleak       # PostgreSQL only
TOKENLEAK_DB_PASSWORD=            # PostgreSQL only

# ── AI Provider ───────────────────────────────────────────────────────────────
TOKENLEAK_AI_PROVIDER=openai      # openai | ollama
TOKENLEAK_AI_API_KEY=sk-...       # OpenAI API key (not needed for Ollama)
TOKENLEAK_AI_API_URL=             # Custom base URL (Ollama: http://localhost:11434/v1)
TOKENLEAK_AI_MODEL=gpt-4o         # Model name (Ollama: llama3.1:70b, etc.)
TOKENLEAK_AI_CONTEXT_WINDOW=262144
TOKENLEAK_AI_MAX_ITERATIONS=50    # Max agent tool-call iterations per scan

# ── Scanner ───────────────────────────────────────────────────────────────────
TOKENLEAK_PREFILTER_ENABLED=true           # Set false to send all content to AI
TOKENLEAK_MAX_REPO_SIZE_MB=2048            # Skip repos larger than this
TOKENLEAK_MAX_FILE_SIZE_MB=10             # Skip individual files larger than this
TOKENLEAK_CLONE_TIMEOUT_SEC=300
TOKENLEAK_CLONE_DIR=/tmp/tokenleak_clones  # Temp dir for repo clones
TOKENLEAK_PARALLEL_REPOS=1                 # Concurrent repo scans

# ── Git Providers ─────────────────────────────────────────────────────────────
TOKENLEAK_GITHUB_TOKEN=ghp_...
TOKENLEAK_GITLAB_TOKEN=glpat-...
TOKENLEAK_GITLAB_URL=https://gitlab.com
TOKENLEAK_GITEA_TOKEN=
TOKENLEAK_GITEA_URL=https://gitea.example.com

# ── Input: Repos List ─────────────────────────────────────────────────────────
# Path to file with repos (local path or inside config repo)
TOKENLEAK_REPOS_LIST_PATH=repos.txt
# Optional: pull repos list from a git repository
TOKENLEAK_CONFIG_REPO_URL=
TOKENLEAK_CONFIG_REPO_TOKEN=

# ── Agent Prompt ──────────────────────────────────────────────────────────────
# Local path or path inside config repo
TOKENLEAK_AGENT_MD_PATH=agent.md

# ── Notifications: Mattermost ─────────────────────────────────────────────────
TOKENLEAK_MATTERMOST_URL=https://mattermost.example.com
TOKENLEAK_MATTERMOST_TOKEN=
TOKENLEAK_MATTERMOST_CHANNEL=tokenleak-alerts

# ── Logging ───────────────────────────────────────────────────────────────────
TOKENLEAK_SYSLOG_ENABLED=true
TOKENLEAK_SYSLOG_HOST=           # Empty = local syslog socket
TOKENLEAK_SYSLOG_PORT=514

# ── Process Lock ──────────────────────────────────────────────────────────────
TOKENLEAK_LOCK_FILE=/tmp/tokenleak.pid
